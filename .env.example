NODE_ENV=development
PORT=3000

# PostgreSQL (sesuaikan dengan docker-compose)
DATABASE_URL=postgres://mabrur:mabrur_secret@localhost:5432/mabrur

# JWT — ganti dengan string acak minimal 32 karakter
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=ganti-dengan-string-acak-yang-panjang-minimal-32-karakter
JWT_REFRESH_SECRET=ganti-dengan-string-acak-lain-yang-berbeda-dari-jwt-secret

# Enkripsi data sensitif (passport, catatan medis) — WAJIB 64 karakter hex (32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Integrasi Safar: token service-to-service (min 32 char) — samakan dgn MABRUR_SERVICE_TOKEN di Safar
SAFAR_SYNC_TOKEN=
